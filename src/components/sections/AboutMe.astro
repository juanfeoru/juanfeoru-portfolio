---
import Aboutme from '../../assets/icons/Aboutme.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id='about' class='py-20 px-6'>
  <div class='max-w-[1440px] mx-auto grid md:grid-cols-2 gap-12 items-center'>
    <div class='flex justify-center'>
      <Aboutme class='max-w-sm md:max-w-[500px] w-full' />
    </div>

    <div class='flex flex-col gap-6'>
      <h2 class='text-3xl md:text-4xl'>
        {t('about.title.about')} <span class='font-extrabold'>{t('about.title.me')}</span>
      </h2>

      <p class='text-zinc-500 leading-relaxed dark:text-zinc-400'>
        {t('about.p1')}
      </p>

      <p class='text-zinc-500 leading-relaxed dark:text-zinc-400'>
        {t('about.p2')}
      </p>

      <p class='text-zinc-500 leading-relaxed dark:text-zinc-400'>
        {t('about.p3')}
      </p>
    </div>
  </div>
</section>
