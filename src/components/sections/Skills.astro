---
import { skillGroups } from '../../data/skills';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id='skills' class='py-20 max-w-[1440px] mx-auto px-6'>
  <h2 class='text-3xl md:text-4xl text-center mb-12'>
    {t('skills.title.my')}<span class='font-bold'>{t('skills.title.skills')}</span>
  </h2>

  <p
    class='text-zinc-500 text-center max-w-xl mx-auto mb-12 dark:text-zinc-400'
  >
    {t('skills.description')}
  </p>

  <div class='flex flex-col gap-12'>
    {
      skillGroups.map((group) => (
        <div>
          <h3 class='text-xl font-semibold mb-6 text-center'>
            {group.category}
          </h3>

          <div class='grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8'>
            {group.skills.map((skill) => {
              const Icon = skill.icon;

              return (
                <div class='group flex flex-col items-center justify-center gap-4 p-6 border-2 border-black rounded-lg transition-all duration-300 hover:bg-linear-to-br hover:from-black hover:to-neutral-700 hover:-translate-y-1 hover:shadow-md dark:border-primary-textDark dark:hover:from-zinc-800 dark:hover:to-zinc-600'>
                  <Icon class='size-12 md:size-14 text-dark group-hover:invert transition-all duration-300 group-hover:scale-110 dark:group-hover:invert-0 dark:text-white' />
                  <p class='font-semibold text-sm group-hover:text-white dark:group-hover:text-primary-textDark'>
                    {skill.name}
                  </p>
                </div>
              );
            })}
          </div>
        </div>
      ))
    }
  </div>
</section>
