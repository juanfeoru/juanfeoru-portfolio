---
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const targetLang = lang === 'en' ? 'es' : 'en';

// Define the href for the language toggle.
const targetUrl = targetLang === 'en' ? '/' : `/${targetLang}/`;

const isActive = (checkLang: string) => lang === checkLang;
---

<a
  href={targetUrl}
  class="font-bold flex items-center gap-1 text-sm md:text-base px-2 py-1 transition-all duration-300 hover:scale-105"
  aria-label={`Switch to ${targetLang === 'en' ? 'English' : 'Spanish'}`}
>
  <span class={`transition-colors ${isActive('en') ? 'text-primary-textDark dark:text-black md:text-black md:dark:text-primary-textDark' : 'text-zinc-600 dark:text-zinc-400 font-normal hover:text-black dark:hover:text-white'}`}>EN</span>
  <span class="text-zinc-400 dark:text-zinc-600 font-normal">|</span>
  <span class={`transition-colors ${isActive('es') ? 'text-primary-textDark dark:text-black md:text-black md:dark:text-primary-textDark' : 'text-zinc-600 dark:text-zinc-400 font-normal hover:text-black dark:hover:text-white'}`}>ES</span>
</a>
