---
const { project, index } = Astro.props;
import { Image } from 'astro:assets';
---

<article
  class={`grid md:grid-cols-2 gap-10 items-center
  ${index % 2 !== 0 ? 'md:[&>.image-container]:order-2' : ''}`}
>
  <div class='relative group image-container'>
    <div class='overflow-hidden rounded-2xl'>
      <Image
        src={project.image}
        alt={`${project.name} project preview`}
        class='rounded-2xl w-full shadow-lg group-hover:scale-105 transition duration-700'
      />
    </div>

    <div
      class='absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100
      transition duration-300 flex items-center justify-center rounded-2xl'
    >
      <a
        href={project.demo}
        target='_blank'
        rel='noopener noreferrer'
        class='px-6 py-3 bg-white text-black font-semibold rounded-lg opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition duration-300'
      >
        Live Demo
      </a>
    </div>
  </div>

  <div class='flex flex-col gap-5'>
    <span class='text-zinc-700 font-extrabold text-4xl'>
      {project.id}
    </span>

    <div class='flex items-center gap-4'>
      <h3 class='text-white text-3xl font-bold text-pretty'>
        {project.name}
      </h3>
    </div>

    <p class='text-zinc-500 text-pretty'>
      {project.description}
    </p>
    <a
      href={project.github}
      target='_blank'
      rel='noopener noreferrer'
      class='text-zinc-400 hover:text-white transition'
      aria-label='View GitHub repository'
    >
      <svg
        xmlns='http://www.w3.org/2000/svg'
        class='w-6 h-6'
        fill='currentColor'
        viewBox='0 0 24 24'
      >
        <path
          d='M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.87 10.93c.58.1.79-.25.79-.56
          0-.28-.01-1.02-.02-2-3.2.7-3.87-1.54-3.87-1.54-.52-1.32-1.28-1.67-1.28-1.67
          -1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.76 2.7 1.25
          3.35.96.1-.75.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.7
          0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06
          0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.8 0
          c2.2-1.5 3.17-1.18 3.17-1.18.64 1.59.24 2.77.12 3.06
          .74.81 1.18 1.84 1.18 3.1
          0 4.43-2.69 5.4-5.25 5.68
          .41.35.77 1.03.77 2.07
          0 1.5-.01 2.71-.01 3.08
          0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12
          C23.5 5.65 18.35.5 12 .5z'
        ></path>
      </svg>
    </a>
  </div>
</article>
