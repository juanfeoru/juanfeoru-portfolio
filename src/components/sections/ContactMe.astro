---
import { socialLinks } from '../../data/socialLinks';
import Location from '../../assets/icons/Location.astro';
import Briefcase from '../../assets/icons/Briefcase.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class='py-20 px-6' id='contact'>
  <div class='max-w-[1200px] mx-auto grid md:grid-cols-2 gap-12'>
    <div>
      <form
        name='contact'
        method='POST'
        data-netlify='true'
        action='/thank-you'
      >
        <div class='flex flex-col gap-2'>
          <label for='name' class='text-sm font-medium'> {t('contact.form.nameLabel')} </label>
          <input
            id='name'
            name='name'
            type='text'
            required
            class='border border-black bg-transparent rounded-md py-3 px-4 placeholder:text-zinc-500 transition dark:border-primary-textDark dark:placeholder:text-zinc-400'
            placeholder={t('contact.form.namePlaceholder')}
          />
        </div>

        <div class='flex flex-col gap-2'>
          <label for='email' class='text-sm font-medium mt-2'> {t('contact.form.emailLabel')} </label>
          <input
            id='email'
            name='email'
            type='email'
            required
            class='border border-black bg-transparent rounded-md py-3 px-4 placeholder:text-zinc-500 transition dark:border-primary-textDark dark:placeholder:text-zinc-400'
            placeholder={t('contact.form.emailPlaceholder')}
          />
        </div>

        <div class='flex flex-col gap-2'>
          <label for='message' class='text-sm font-medium mt-2'>
            {t('contact.form.messageLabel')}
          </label>
          <textarea
            id='message'
            name='message'
            required
            rows='4'
            class='border border-black bg-transparent rounded-md py-3 px-4 placeholder:text-zinc-500 transition dark:border-primary-textDark dark:placeholder:text-zinc-400'
            placeholder={t('contact.form.messagePlaceholder')}></textarea>
        </div>

        <div class='flex flex-wrap items-center gap-6 mt-2'>
          <button
            type='submit'
            class='bg-black text-white px-6 py-3 rounded-md font-medium transition-all duration-300 hover:-translate-y-1 hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2 cursor-pointer dark:bg-primary-textDark dark:text-primary-bgDark'
          >
            {t('contact.form.submit')}
          </button>

          <div class='flex gap-4'>
            {
              socialLinks.map((link) => {
                const Icon = link.icon;

                return (
                  <a
                    href={link.href}
                    target='_blank'
                    rel='noopener noreferrer'
                    aria-label={link.name}
                    class='group border-2 border-black rounded-md p-3 hover:bg-black hover:text-white hover:scale-110 transition size-11 flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2 dark:border-primary-textDark dark:hover:bg-primary-textDark dark:hover:text-primary-bgDark'
                  >
                    <Icon class='size-5 group-hover:invert dark:group-hover:invert-0 dark:group-hover:text-black dark:text-white' />
                  </a>
                );
              })
            }
          </div>
        </div>
      </form>
    </div>

    <div class='flex flex-col gap-6 justify-center'>
      <h2 class='text-3xl md:text-4xl font-bold'>
        {t('contact.info.title')}
      </h2>

      <p class='text-zinc-500 leading-relaxed dark:text-zinc-400'>
        {t('contact.info.description')}
      </p>

      <div class='flex flex-col gap-1 text-sm text-zinc-500 dark:text-zinc-400'>
        <span class='flex items-center gap-2'>
          <Location />
          {t('contact.info.location')}
        </span>
        <span class='flex items-center gap-2'>
          <Briefcase />
          {t('contact.info.availability')}
        </span>
      </div>

      <p class='font-semibold text-lg'>felipeortega383@gmail.com</p>
    </div>
  </div>
</section>
